*{
    margin: 0;
    padding: 0;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    box-sizing: border-box;
}
header{
    position: relative;
     width: 100%;
  display: block;
}
header .header-link-bar{
    display: flex;
    margin: 0;
    height: 30px;
    gap: 400px;
    align-items: center;
    padding: 5px 5px;
    background-color: #f1f1f2;
}
header .header-banner{
    width: 100%;
    height: 4rem;
    background-color: black;
}
header .header-banner img{
    width: 95%;
    height: 100%;
}

header .sell{
    display: flex;
    align-items: center;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    margin-right: 0px;
}
header .sell a img{
    width: 20px;
    margin-top: 10px;
}
header .sell a{
    text-decoration: none;
    color: #f68b1e;
    padding-top: 10px;
    font-size: 14px;
    margin-left: 5px;
    margin-bottom: 10px;
}
header .sell a:hover{
    text-decoration: underline;
    cursor: pointer;
}
header .middle{
    margin-top: 1px;
}
header .middle img{
    width: 75px;
    padding-right: 5px;
    margin-top: 4px;

}
header .middle img :hover{
    background-color: #f68b1e;
}

.hamburger-menu {
    position: sticky;
    top: 0;
    background-color: white;
    box-shadow: 0 5px 10px rgba(0,0,0,0.1);
    width: 100%;
    height: 70px;
    display: flex;
    z-index: 1000;
    padding: 20px;
    align-items: center;
}

.menu-icon {
    font-size: 28px;
    cursor: pointer;
    padding: 20px 0px 20px 0px ;
    background-color: transparent;
    color: #000;
    width: 30px;
    font-weight: bolder;
}

.main-menu {
    list-style: none;
    padding: 0;
    margin: 0;
    position: absolute;
    top: 100%;
    left: 0;
    background-color: #f1f1f2;
    min-width: 200px;
    height: fit-content;
    display: none;
    box-shadow: 0 8px 16px rgba(0,0,0,0.2);
    z-index: 10;
}

.menu-icon:hover + .main-menu, .main-menu:hover {
    display: block;
}

.menu-icon:hover {
    color: #f68b1e;
    display: block;
}

.menu-item a {
    display: flex;
    padding: 10px 15px;
    color: black;
    line-height: 1.2rem;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    text-decoration: none;
    transition: background-color 0.3s;
    height: 30px;
}

.menu-item:hover > a{
    color: #f68b1e;
}
.menu-item a svg{
    width: 20px;
    height: 20px;
    margin-right: 8px;
    fill: currentColor;
}
.menu-item a svg:hover{
    color: #f68b1e;
}

.submenu-panel {
    display: none;
    position: absolute;
    top: 0;
    height: 500px;
    left: 100%;
    background-color: #f1f1f1;
    color: #333;
    padding: 20px;
    min-width: 400px;
    box-shadow: 8px 0 16px rgba(0,0,0,0.2);
}

.menu-item.has-submenu:hover .submenu-panel {
    display: flex;
    flex-direction: row;
    gap: 20px;
    white-space: nowrap;
}

.submenu-column a h4 {
    margin-top: 0;
    color: #333;
    padding-bottom: 5px;
    margin-bottom: 10px;
    cursor: pointer;
    text-decoration: underline;
}
.submenu-column h4:hover {
    color: #f68b1e;
}

.submenu-column ul {
    list-style: none;
    padding: 0;
    margin: 0;
}

.submenu-column a {
    color: #333;
    padding: 5px 0;
    font-size: 0.9em;
}

.submenu-column li:hover a {
    text-decoration: underline;
}

nav a img{
    width: 150px;
    padding: 28px 0px 20px 0px;
    margin-left: 10%;
}
.search-container {
  display: flex;
  align-items: center;
  margin-left: 5%;

}

form {
  display: flex;
  border: 1px solid #c0c0c1;
  padding: 2px 1px 1px 1px;
  border-radius: 5px;
  height: 50px;
  width: 100%;
}
form svg{
    width: 30px;
    height: 30px;
    padding-left: 7px;
    margin-left: 7px;
    margin-right: 7px;
    align-self: center;
    fill: currentColor;
}

.search-input {
  padding: 10px;
  border: none;
  outline: none;
  width: 500px;

}

.search-button {
  padding: 10px 20px;
  border: none;
  background-color: #f68b1e;
  color: white;
  cursor: pointer;
  font-size: 14px;
  margin-left: 7px;
  border-radius: 5px;
  height: 50px;
}

.search-button:hover {
  background-color: #d5710e;
}

.dropbtn , .dropbtn-2{
 background-color: transparent;
 color: black;
 padding: 10px;
 font-size: 16px;
 border: none;
 font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
 cursor: pointer;
 margin-left: 30px;
 cursor: pointer;
  display: flex;
  align-items: center;
  gap: 3px;
}

.shop-btn{
 background-color: transparent;
 color: black;
 padding: 10px;
 font-size: 16px;
 border: none;
 font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
 cursor: pointer;
}
.dropdown {
 position: relative;
 display: inline-block;
}
.dropdown button img{
    width: 20px;
    margin-right: 3px;
}

.dropdown-content.show {
  display: block;
}

.dropdown-content a {
 color: black;
 padding: 12px 16px;
 text-decoration: none;
 display: block;
 width: 100%;
 text-align: left;
}

.dropdown-content a svg{
    width: 20px;
    height: 20px;
    margin-right: 8px;
    fill: currentColor;
}

.dropdown-content .Sign-in {
 color: black;
 background-color: #f68b1e;
 position: relative;
 padding: 10px 14px;
 display: block;
 border: none;
 border-radius: 5px;
 margin-right: 20px;
 margin-left: 10px;
 justify-items: center;
 width: 160px;
}
.dropdown-content #svg-button {
 color: black;
 background-color: #f68b1e;
 position: relative;
 padding: 10px 0px 5px 0px;
 display: block;
 border: none;
 border-radius: 5px;
 margin-right: 20px;
 margin-left: 0px;
 margin-bottom: 15px;
 justify-items: center;
 width: 160px;
}

#svg-button svg {
width: 20px;
height: 20px;
padding-top: 5px;
align-self: center;
fill: currentColor;
}
.dropdown-content button svg{
    width: 20px;
}

.dropdown-content a:hover {
 background-color: #f1f1f1;
}
.dropdown-content button:hover {
 background-color: #d5710e;
}

.dropdown.active .dropbtn {
 color: #f68b1e;
}
.dropdown.active .caret {
  transform: rotate(-135deg);
}
.caret {
  border: solid #333;
  border-width: 0 2px 2px 0;
  display: inline-block;
  padding: 4px;
  margin-bottom: 3px;
  margin-left: 7px;
  transform: rotate(45deg);
  transition: transform 0.3s ease;

}

.section-1 {
  display: flex;
  flex-direction: row;
  height: 2000px;
  background-color: #f1f1f2;
}

.sidebar {
    width: 18rem;
    background: #ffffff;
    border-right: 1px solid #ddd;
    height: fit-content;
    border-radius: 5px ;
    justify-content: center;
    margin-top:  10px;
    margin-left: 2%;
    margin-right: 1%;

}

.filter-section {
    margin-bottom: 10px;

}
.filter-section label input{
    margin: 10px 0px 0px 0px ;
}

.filter-section h3 {
    margin-bottom: 10px;
    font-size: 16px;
    font-weight: 500;
    padding-left: 3%;
    text-transform: uppercase;

}
.apply{
    color: #f68b1e; 
    background-color: white; 
    border: none;  
    padding: 0px 12px 0px 8px; 
    font-size: 14px; font-weight: 500; 
    cursor: pointer;
    border-radius: 5px;
}
.apply:hover {
    background-color: rgba(237,145,7,0.443);
}
.filter-options {
    padding-left: 5px;
    border-bottom: 1px solid #ccc;
    font-size: 16px;
    padding-bottom: 2px;
}

.filter-option{
    border-bottom: 1px solid #ccc;
    padding-bottom: 1px;
}

.filter-option a {
 color: black;
 padding: 5px 35px 5px 35px;
 text-decoration: none;
 display: block;
 font-size: 15px;
 width: 100%;
 height: 40px;
 text-align: left;
}

.filter-option a:hover {
 background-color: #f1f1f2;
 border-left: 1px solid #e0e0e0;
 border-right: 1px solid #e0e0e0;
}

.filter-options input[type="checkbox"] {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  cursor: pointer;
  accent-color: #f68b1e;
  margin: 7px 0 0 7px;
}

.filter-options.has-square input[type="checkbox"] {
  -webkit-appearance: none;
  -moz-appearance: none;
  appearance: none;
  width: 20px;
  height: 20px;
  padding-bottom: 2px;
  border: 2.3px solid #aeadae;
  border-radius: 2px;
  cursor: pointer;
  position: relative;
}

.filter-options.has-square input[type="checkbox"]::after {
  content: "";
  position: absolute;
  inset: -2px;
  border-radius: 50%;
  box-shadow: 0 0 0 0 rgba(237,145,7,0);
  pointer-events: none;
}

.filter-options.has-square input[type="checkbox"]:hover::after {
  box-shadow: 0 0 0 6px rgba(237,145,7,0.443);
}

.filter-options:not(.has-square) input[type="checkbox"]:hover {
  box-shadow: 0 0 0 6px rgba(237,145,7,0.443);
}

.filter-options label {
    display: block;
    margin-bottom: 5px;
    cursor: pointer;
    margin: 4px 0px 12px 5px;
    word-spacing: 1px;
}
.filter-options label span{
    color: #f68b1e;
    text-transform: uppercase;
    font-family: Georgia, 'Times New Roman', Times, serif;

}
.filter-options label svg{
width: 20px;
height: 20px;
padding-top: 5px;
bottom: 50px;
align-self: center;
fill: currentColor;
color: #f68b1e;

}

.search-container-1 {
  display: flex;
  width: 220px;
  justify-self: center;

}
.search-container-1 svg {
    width: 25px;
}



.search-input-1 {
  padding: 0px 4px 0px 2px ;
  border: none;
  outline: none;

}

input[type="range"] {
  -webkit-appearance: none;
  width: 90%;
  height: 6px;
  justify-items: center;
  background: #ddd;
  border-radius: 5px;
  outline: none;
}

input[type="range"]::-webkit-slider-runnable-track {
  height: 6px;
  background: #f68b1e;
  border-radius: 5px;
}
input[type="range"]::-moz-range-track {
  height: 6px;
  background: #f68b1e;
  border-radius: 5px;
}

input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #f68b1e;
  cursor: pointer;
  margin-top: -5px;
}
input[type="range"]::-moz-range-thumb {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #f68b1e;
  cursor: pointer;
}
input[type="checkbox"] {
  appearance: none;
  width: 22px;
  height: 22px;
  border: 2px solid #9e9e9e;
  border-radius: 50%;
  position: relative;
  margin: 0px 0px 0px 10px;
  cursor: pointer;
  margin-right: 8px;
  transition: background 0.3s ease, border-color 0.3s ease;
}

input[type="checkbox"]:checked::after {
  content: "";
  width: 10px;
  height: 10px;
  background: orange;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.dropdown-content input[type="radio"] {
  accent-color: #f68b1e;
  border: none;
}

.flow{
    padding:12px 0px 8px 2% ;
    background-color: #f1f1f2;
}

.main-content {
    flex: 1;
    padding: 20px;
    background: #fff;
    overflow-y: auto;
    background: #ffffff;
    border-right: 1px solid #ddd;
    height: 100vh;
    width: 100vh;
    border-radius: 5px ;
    margin-top:  10px;
    margin-left: 0.4%;
    margin-right: 3%;
}
.product-top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0px 10px px 0px ;
  
}

.top-left {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.dropbtn {
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 3px;
}

.caret {
  border: solid #333;
  border-width: 0 2px 2px 0;
  display: inline-block;
  padding: 3px;
  transform: rotate(45deg);
  transition: transform 0.3s ease;
}

.dropdown {
  position: relative;
}

.dropdown-content {
  display: none;
  position: absolute;
  background: #fff;
  box-shadow: 0 4px 8px rgba(0,0,0,0.2);
  padding: 0px 0px 5px 0px;
  min-width: 220px;
  z-index: 1;
}

.dropdown-content label {
  display: block;
  margin: 6px 0;
  cursor: pointer;
  width: 100%;
  padding: 10px 0px 10px 0px;
}


.dropdown.active .dropdown-content {
  display: block;
}

.dropdown.active .caret {
  transform: rotate(-135deg);
}

.dropdown-content input[type="radio"] {
  appearance: none;
  width: 22px;
  height: 22px;
  border: 2px solid #9e9e9e;
  border-radius: 50%;
  position: relative;
  margin: 0px 0px 0px 10px;
  cursor: pointer;
  margin-right: 8px;
  transition: background 0.3s ease, border-color 0.3s ease;
}

.dropdown-content input[type="radio"]:checked::before {
  content: "";
  width: 10px;
  height: 10px;
  background: orange;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.dropdown-content input[type="radio"]:hover {
  box-shadow: 0 0 0 6px rgba(237, 145, 7, 0.443);
  border-radius: 50px;
}

.product-top-bar.scroll{
    text-wrap: nowrap;
    padding: 8px 0px 0px 0px;
    overflow-x: auto;           
  overflow-y: hidden;      
  -webkit-overflow-scrolling: touch; 
  scrollbar-width: none;
  padding-bottom: 16px;

}

.product-top-bar.buttons{
    margin-top: 15px;
    border-top: 1px solid #f1f1f1;
    border-bottom:1px solid #f1f1f1 ;
    align-content: center;
}
.product-top-bar.buttons .dropbtn,.dropbtn-2 {
    background-color: #f1f1f1;
    margin: 7px 7px 7px 0px;
    border-radius: 7px;
    
}
/* Container styling */
#product-container {
  display: flex;
  flex-wrap: wrap;         /* allow wrapping to next line */
  justify-content: space-between;
  gap: 20px;               /* spacing between cards */
}

/* Product card styling */
.product-card {
  flex: 1 1 calc(25% - 20px); /* 4 per row (25% each minus gap) */
  box-sizing: border-box;
  border: 1px solid #ccc;
  padding: 16px;
  background: #fff;
}

/* Responsive adjustment */
@media (max-width: 1024px) {
  .product-card {
    flex: 1 1 calc(33.33% - 20px); /* 3 per row */
  }
}

@media (max-width: 768px) {
  .product-card {
    flex: 1 1 calc(50% - 20px); /* 2 per row */
  }
}

@media (max-width: 480px) {
  .product-card {
    flex: 1 1 100%; /* 1 per row */
  }
}



